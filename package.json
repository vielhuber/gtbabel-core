{
    "scripts": {
        "🔽 js detectdomchanges 🔽": "",
        "js:browserify:detectdomchanges": "browserify ./components/detectdomchanges/script.js --outfile ./components/detectdomchanges/build/bundle.js --debug -g [ browserify-css --minify=true --stripComments=true ] --transform babelify",
        "js:vite:detectdomchanges": "vite build --logLevel error --mode detectdomchanges",
        "js:minify:detectdomchanges": "terser --compress --mangle --output ./components/detectdomchanges/build/bundle.js ./components/detectdomchanges/build/bundle.js",
        "js:watch:detectdomchanges": "onchange ./components/*/*.js --initial --poll 50 --delay 0 --await-write-finish 50 -- onerror \"npm run js:vite:detectdomchanges\" --title \"js:watch:detectdomchanges\" --message \"build failed\" --sound mute",
        "                                                                                                                                                                                                      ": "",
        "🔽 js frontendeditor 🔽": "",
        "js:browserify:frontendeditor": "browserify ./components/frontendeditor/script.js --outfile ./components/frontendeditor/build/bundle.js --debug -g [ browserify-css --minify=true --stripComments=true ] --transform babelify",
        "js:vite:frontendeditor": "vite build --logLevel error --mode frontendeditor",
        "js:minify:frontendeditor": "terser --compress --mangle --output ./components/frontendeditor/build/bundle.js ./components/frontendeditor/build/bundle.js",
        "js:watch:frontendeditor": "onchange ./components/*/*.js --initial --poll 50 --delay 0 --await-write-finish 50 -- onerror \"npm run js:vite:frontendeditor\" --title \"js:watch:frontendeditor\" --message \"build failed\" --sound mute",
        "                                                                                                                                                                                                       ": "",
        "🔽 css frontendeditor 🔽": "",
        "css:sass:frontendeditor": "sass --style compressed --no-source-map ./components/frontendeditor/style.scss ./components/frontendeditor/build/bundle.css",
        "css:sass:dev:frontendeditor": "sass ./components/frontendeditor/style.scss ./components/frontendeditor/build/bundle.css",
        "css:postcss:autoprefixer:frontendeditor": "postcss --use autoprefixer --output ./components/frontendeditor/build/bundle.css ./components/frontendeditor/build/bundle.css",
        "css:watch:frontendeditor": "onchange ./components/*/*.scss --initial --poll 50 --delay 0 --await-write-finish 50 -- onerror \"npm run css:sass:dev:frontendeditor\" --title \"css:watch:frontendeditor\" --message \"build failed\" --sound mute",
        "                                                                                                                                                                                                        ": "",
        "🔽 css languagepicker 🔽": "",
        "css:sass:languagepicker": "sass --style compressed --no-source-map ./components/languagepicker/style.scss ./components/languagepicker/build/bundle.css",
        "css:sass:dev:languagepicker": "sass ./components/languagepicker/style.scss ./components/languagepicker/build/bundle.css",
        "css:postcss:autoprefixer:languagepicker": "postcss --use autoprefixer --output ./components/languagepicker/build/bundle.css ./components/languagepicker/build/bundle.css",
        "css:watch:languagepicker": "onchange ./components/*/*.scss --initial --poll 50 --delay 0 --await-write-finish 50 -- onerror \"npm run css:sass:dev:languagepicker\" --title \"css:watch:languagepicker\" --message \"build failed\" --sound mute",
        "                                                                                                                                                                                                         ": "",
        "🔽 css frontendeditorlinks 🔽": "",
        "css:sass:frontendeditorlinks": "sass --style compressed --no-source-map ./components/frontendeditorlinks/style.scss ./components/frontendeditorlinks/build/bundle.css",
        "css:sass:dev:frontendeditorlinks": "sass ./components/frontendeditorlinks/style.scss ./components/frontendeditorlinks/build/bundle.css",
        "css:postcss:autoprefixer:frontendeditorlinks": "postcss --use autoprefixer --output ./components/frontendeditorlinks/build/bundle.css ./components/frontendeditorlinks/build/bundle.css",
        "css:watch:frontendeditorlinks": "onchange ./components/*/*.scss --initial --poll 50 --delay 0 --await-write-finish 50 -- onerror \"npm run css:sass:dev:frontendeditorlinks\" --title \"css:watch:frontendeditorlinks\" --message \"build failed\" --sound mute",
        "                                                                                                                                                                                                          ": "",
        "🔽 pipelines 🔽": "",
        "js": "npm-run-all --sequential js:vite:* js:minify:*",
        "js:dev": "npm-run-all --sequential js:vite:*",
        "css": "npm-run-all --sequential css:sass:* css:postcss:autoprefixer:*",
        "css:dev": "npm-run-all --sequential css:sass:dev:*",
        "prod": "npm-run-all --parallel js css",
        "dev": "npm-run-all --parallel js:watch:* css:watch:*"
    },
